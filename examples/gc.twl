class Box {
    int v;
    Box(int v) { this.v = v; }
    public int get() { return this.v; }
}

// Each call allocates a Box that becomes unreachable when the call returns.
void makeGarbage() {
    var tmp = new Box(0);
}

var kept = new Box(99);

int i = 0;
while (i < 20) {
    makeGarbage();
    i = i + 1;
}

print(__live());     // 21: kept + 20 pieces of garbage
collect();
print(__live());     // 1: only kept survives
print(kept.get());   // 99: still valid after collection
