abstract class Animal {
    protected int legs;
    public abstract int speak();
    public int legCount() { return this.legs; }
}

class Dog : Animal {
    Dog() { this.legs = 4; }
    public int speak() { return 1; }
}

class Cat : Animal {
    Cat() { this.legs = 4; }
    public int speak() { return 2; }
}

int callSpeak(Animal a) { return a.speak(); }

print(callSpeak(new Dog()));
print(callSpeak(new Cat()));
print(new Dog().legCount());
