class Shape {
    Shape() {}
    public int area() { return 0; }
}

class Square : Shape {
    int side;
    Square(int s) { this.side = s; }
    public int area() { return this.side * this.side; }
}

class Box : Shape {
    int w;
    int h;
    Box(int w, int h) { this.w = w; this.h = h; }
    public int area() { return this.w * this.h; }
}

int areaOf(Shape s) { return s.area(); }

print(areaOf(new Square(5)));
print(areaOf(new Box(3, 4)));
