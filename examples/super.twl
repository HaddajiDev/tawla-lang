class Animal {
    int legs;
    Animal(int n) { this.legs = n; }
    public int legCount() { return this.legs; }
}

class Dog : Animal {
    string name;
    Dog(string n) {
        super(4);
        this.name = n;
    }
    public string who() { return this.name; }
}

var d = new Dog("Rex");
print(d.legCount());
print(d.who());
